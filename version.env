# eng-versioning(7): the single source of truth for this repo's version.
# The Go module lives under go/ (a polyglot layout), so the fork's
# buildGoApplication can't auto-read this file via its pwd-based lookup
# (pwd must contain go.mod, i.e. go/ here) — flake.nix parses it directly
# via builtins.match and threads the value through explicitly (mirrors
# madder's flake.nix, which has the same go/ subdirectory layout). `just
# bump-version` rewrites this file.
export CHREST_VERSION=0.3.1
