.gitsecret/keys/random_seed
!*.secret
extension/secrets/jwt_issuer
extension/secrets/jwt_secret
extension/secrets/jwt_issuer.secret
extension/secrets/jwt_secret.secret
extension/firefox/secrets/jwt_issuer
extension/firefox/secrets/jwt_secret
extension/.secrets-firefox.env
extension/node_modules/

# Dev-only moxy overlay for the chrest-dev entry; absolute paths are
# environment-specific, so keep it out of the repo.
/moxyfile

# `just dagnabit-check` writes regenerated facades to a sibling of
# go/pkgs/ for diffing (dagnabit's -output-dir is module-root
# relative, so /tmp won't work). Cleaned by the recipe's trap, but
# guarded here in case a run is interrupted.
go/pkgs.dagnabit-check.tmp/

# `just check-nix` pins cross-system devShell + package .drvs as GC
# roots here, so the flake's all-systems-eval check (which deep-seqs
# through their drvPaths) doesn't trip on substituted-from-cache FOD
# outputs whose .drv was never landed locally.
.nix-gcroots/
